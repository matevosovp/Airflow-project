# Airflow local runtime
AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=./part1_airflow
AIRFLOW_SHARED_DATA_DIR=/opt/airflow/data

# Source database
DB_SOURCE_HOST=replace-me
DB_SOURCE_PORT=5432
DB_SOURCE_NAME=replace-me
DB_SOURCE_USER=replace-me
DB_SOURCE_PASSWORD=replace-me

# Destination database
DB_DESTINATION_HOST=replace-me
DB_DESTINATION_PORT=5432
DB_DESTINATION_NAME=replace-me
DB_DESTINATION_USER=replace-me
DB_DESTINATION_PASSWORD=replace-me

# S3-compatible storage
S3_BUCKET_NAME=replace-me
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me

# Optional notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
