# Airflow local runtime
AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=./part1_airflow

# Source database
DB_SOURCE_HOST=replace-me
DB_SOURCE_PORT=5432
DB_SOURCE_NAME=replace-me
DB_SOURCE_USER=replace-me
DB_SOURCE_PASSWORD=replace-me

# Optional DVC database override; leave empty to reuse DB_SOURCE_*
DB_DESTINATION_HOST=
DB_DESTINATION_PORT=
DB_DESTINATION_NAME=
DB_DESTINATION_USER=
DB_DESTINATION_PASSWORD=

# S3-compatible storage
S3_BUCKET_NAME=replace-me
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me

# Optional notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
